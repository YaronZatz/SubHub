rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Public listings feed — clients may read; only the server (admin SDK) may write
    match /listings/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // Per-user saved listings
    match /saved_listings/{docId} {
      // get: only the owning user can read their own doc
      allow get: if request.auth != null
                 && resource.data.userId == request.auth.uid;

      // list: any authenticated user can execute a query
      // (clients always query with where('userId','==',uid) — enforced by app code)
      allow list: if request.auth != null;

      // create: userId field must match the authenticated caller
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid;

      // delete: only the owning user can delete
      allow delete: if request.auth != null
                    && resource.data.userId == request.auth.uid;
    }
  }
}
